<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="petstorePU" transaction-type="RESOURCE_LOCAL">

        <!-- Déclaration de toutes les entités -->
        <class>com.petstore.entities.Address</class>
        <class>com.petstore.entities.PetStore</class>
        <class>com.petstore.entities.Product</class>
        <class>com.petstore.entities.Animal</class>
        <class>com.petstore.entities.Fish</class>
        <class>com.petstore.entities.Cat</class>

        <properties>
            <!-- Connexion à la base de données MySQL -->
            <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:mysql://localhost:3306/petstore?createDatabaseIfNotExist=true&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user"     value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="root"/>

            <!-- Hibernate : création automatique du schéma -->
            <property name="hibernate.hbm2ddl.auto"  value="update"/>
            <property name="hibernate.dialect"        value="org.hibernate.dialect.MySQLDialect"/>

            <!-- Affichage des requêtes SQL générées (pratique pour le debug) -->
            <property name="hibernate.show_sql"       value="true"/>
            <property name="hibernate.format_sql"     value="true"/>
        </properties>

    </persistence-unit>

</persistence>
